# Local game repo clones — operated on by the swarm, never tracked here.
# These match top-level dirs only; nested paths (e.g. scripts/store-screenshots/
# scenes/house-mafia/) are not affected by the leading slash.
/arrow-puzzle-testing/
/Bloxplode-Beta/
/house-mafia/

# Daemon runtime state
build.log
.daemon.lock
.daemon-state/

# Council runtime state (review.log accumulates per-run timestamps;
# review-context.md is rebuilt at the start of every run)
council/review.log
council/review-context.md

# OS / editor noise
.DS_Store
*.swp
.idea/
.vscode/
.claude/

# Per-agent runtime logs (rebuilt on every run, no value in tracking)
agents/*/*.log

# Local secrets
daemon/config.local.sh
.env
